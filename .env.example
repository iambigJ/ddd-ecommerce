# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
API_PORT=3000
GLOBAL_PREFIX=api

# ============================================
# LOGGER
# ============================================
LOGGER_APP_NAME=ddd-ecommerce
LOGGER_LOG_LEVEL=debug
LOGGER_LOG_DIR=./logs
LOGGER_MAX_FILE_SIZE=20m
LOGGER_MAX_FILES=30d
LOGGER_ENABLE_CONSOLE=true
LOGGER_EXCEPTION_FILE_PATH=./logs/ddd-ecommerce

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Used by Drizzle CLI (generate / migrate / studio)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ddd-ecommerce
# Used by the NestJS api-gateway at runtime
MAIN_POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/ddd-ecommerce
PG_POOL_KEEP_ALIVE=true
doMigrations =
PG_CONNECTION_TIMEOUT=5000
PG_RETRY_COUNT=3
PG_RETRY_DELAY=2000

# ============================================
# REDIS (sessions & idempotency)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=ddd-ecommerce:v1:
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_COMMAND_TIMEOUT=14000
REDIS_CONNECT_TIMEOUT=2000
REDIS_RECONNECT_DELAY=1000
REDIS_MAX_CONNECTION_ATTEMPTS=4
# Optional overrides for customer auth key namespaces
REDIS_SESSION_PREFIX=session:
REDIS_CUSTOMER_SESSIONS_PREFIX=customer:sessions:

# ============================================
# JWT (customer auth)
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET_ACCESS_TOKEN=change-me-use-openssl-rand-hex-32-min-32-chars
JWT_SECRET_REFRESH_TOKEN=change-me-use-openssl-rand-hex-32-min-32-chars
JWT_EXPIRE_ACCESS_TOKEN_IN=24h
JWT_EXPIRE_REFRESH_TOKEN_IN=7d

# ============================================
# PAYMENTS (mock providers)
# ============================================
PAYMENT_RETRY_COUNT=1
PAYMENT_RETRY_DELAY_MS=0
PAYMENT_PROVIDER_TIMEOUT_MS=2000
PAYMENT_DEFAULT_PROVIDER=stripe
PAYMENT_FALLBACK_CHAIN=stripe,paypal
STRIPE_MOCK_FORCE_FAILURE=false
PAYPAL_MOCK_FORCE_FAILURE=false

# ============================================
# I18N
# ============================================
I18N_DEFAULT_LANG=en
I18N_FALLBACK_LANG=en
I18N_SUPPORTED_LANGS=en,fa
