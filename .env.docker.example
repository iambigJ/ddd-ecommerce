# Copy to .env.docker and adjust before: docker compose up --build
# Used by the api-gateway service via env_file in docker-compose.yml

NODE_ENV=production
API_PORT=3000
GLOBAL_PREFIX=api

MAIN_POSTGRES_URI=postgresql://postgres:postgres@postgres:5432/ddd-ecommerce
DO_MIGRATIONS=true
PG_POOL_KEEP_ALIVE=true
PG_CONNECTION_TIMEOUT=5000
PG_RETRY_COUNT=3
PG_RETRY_DELAY=2000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_KEY_PREFIX=ddd-ecommerce:v1:
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_COMMAND_TIMEOUT=14000
REDIS_CONNECT_TIMEOUT=2000
REDIS_RECONNECT_DELAY=1000
REDIS_MAX_CONNECTION_ATTEMPTS=4

# Generate with: openssl rand -hex 32
JWT_SECRET_ACCESS_TOKEN=change-me-use-openssl-rand-hex-32-min-32-chars
JWT_SECRET_REFRESH_TOKEN=change-me-use-openssl-rand-hex-32-min-32-chars
JWT_EXPIRE_ACCESS_TOKEN_IN=24h
JWT_EXPIRE_REFRESH_TOKEN_IN=7d

PAYMENT_RETRY_COUNT=1
PAYMENT_RETRY_DELAY_MS=0
PAYMENT_PROVIDER_TIMEOUT_MS=2000
PAYMENT_DEFAULT_PROVIDER=stripe
PAYMENT_FALLBACK_CHAIN=stripe,paypal
STRIPE_MOCK_FORCE_FAILURE=false
PAYPAL_MOCK_FORCE_FAILURE=false

I18N_FALLBACK_LANG=en
