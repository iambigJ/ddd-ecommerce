				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success && res.data?.accessToken) {",
									"  pm.collectionVariables.set('accessToken', res.data.accessToken);",
									"  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
									"}",
									"if (res.data?.customer?.email) {",
									"  pm.collectionVariables.set('customerEmail', res.data.customer.email);",
									"}"
								],
								"type": "text/javascript"
							}
						}
